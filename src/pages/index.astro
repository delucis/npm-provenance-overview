---
import InsecureIcon from '../assets/insecure-icon.svg';
import ProvenanceIcon from '../assets/provenance-icon.svg';
import TrustedIcon from '../assets/trusted-icon.svg';
import Layout from '../layouts/Layout.astro';

const content = {
	title: 'npm provenance overview',
	description: 'Quickly see publishing security for a maintainer’s npm packages.',
	categories: [
		{
			Icon: TrustedIcon,
			title: 'Trusted',
			description: `These packages were published with trusted publishing, attesting to the package’s provenance and also reducing the risk of credentials being leaked.`,
		},
		{
			Icon: ProvenanceIcon,
			title: 'Provenance',
			description: `These packages were published with an attestation that the package contents were generated by a specific CI workflow.`,
		},
		{
			Icon: InsecureIcon,
			title: 'Insecure',
			description: `These packages were published without any guarantees about where the package contents come from.`,
		},
	],
	maintainers: [
		'ai',
		'antfu',
		'bluwy',
		'danielroe',
		'developit',
		'dominik_g',
		'fb',
		'feross',
		'fredkschott',
		'isaacs',
		'jdalton',
		'mafintosh',
		'mathias',
		'mozilla-npm',
		'natemoo-re',
		'nodejs-foundation',
		'npm-cli-ops',
		'oss-bot',
		'qix',
		'rich_harris',
		'sindresorhus',
		'svelte-admin',
		'tjholowaychuk',
		'tootallnate',
		'typescript-bot',
		'vitebot',
		'vitestbot',
		'wooorm',
		'yusukebe',
		'yyx990803',
	],
};
---

<Layout>
	<main>
		<h1>{content.title}</h1>
		<p>{content.description}</p>

		<form>
			<label for="npm-maintainer">Maintainer</label>
			<input type="text" name="maintainer" id="npm-maintainer" required />
			<button class="button">Show packages</button>
		</form>

		<p>
			Try an example: {
				content.maintainers.map((name, i, { length }) => {
					return (
						<>
							<!-- prettier-ignore -->
							<a href={`?maintainer=${name}`}>{name}</a>{i < length - 1 ? ',' : ''}
						</>
					);
				})
			}
		</p>

		<hr />

		<div data-result-slot aria-live="polite"></div>

		<template data-loading-template>
			<h2>Loading packages for <span data-query></span><span class="loader"></span></h2>
		</template>

		<template data-result-template>
			<div class="results">
				<h2>Packages for <span data-query></span></h2>
				<div class="categories">
					{
						content.categories.map(({ Icon, title, description }) => (
							<div>
								<h3>
									<Icon aria-hidden="true" /> {title}
								</h3>
								<p>{description}</p>
								<ol {...{ [`data-${title.toLowerCase()}-list`]: '' }} />
							</div>
						))
					}
				</div>
			</div>
		</template>
	</main>

	<script>
		const form = document.querySelector('form')!;
		const resultSlot = document.querySelector<HTMLElement>('[data-result-slot]')!;
		const loadingTemplate = document.querySelector<HTMLTemplateElement>(
			'template[data-loading-template]'
		)!;
		const resultsTemplate = document.querySelector<HTMLTemplateElement>(
			'template[data-result-template]'
		)!;
		const title = document.querySelector('title')!;

		form.addEventListener('submit', submitForm);

		const q = new URLSearchParams(window.location.search).get('maintainer');
		if (q) {
			form.maintainer.value = q;
			submitForm();
		}

		async function submitForm(event?: SubmitEvent) {
			try {
				event?.preventDefault();
				const query = form.maintainer.value.toLowerCase();
				const loadingState = loadingTemplate.content.cloneNode(true) as HTMLElement;
				loadingState.querySelector('[data-query]')!.textContent = query;
				resultSlot.replaceChildren(loadingState);

				title.innerText = `${query} | npm provenance overview`;
				const path = new URL(`?maintainer=${query}`, window.location.href).href;
				window.history.pushState({ path }, '', path);

				const packages = await getPackages(query);

				const trusted = packages.filter((pkg) => pkg.provenance === 'trustedPublisher');
				const provenance = packages.filter((pkg) => pkg.provenance === true);
				const insecure = packages.filter((pkg) => !pkg.provenance);

				const template = resultsTemplate.content.cloneNode(true) as HTMLDivElement;
				template.querySelector('[data-query]')!.textContent = query;

				for (const [key, list] of Object.entries({ trusted, provenance, insecure })) {
					const target = template.querySelector(`[data-${key}-list]`)!;
					if (list.length === 0) {
						const noResultP = document.createElement('p');
						const strong = document.createElement('strong');
						strong.innerText = {
							trusted: 'No packages found using trusted publishing.',
							provenance: 'No packages found using provenance attestation.',
							insecure: 'No packages found using insecure publishing.',
						}[key]!;
						noResultP.append(strong);
						target.replaceWith(noResultP);
					}
					for (const pkg of list) {
						const li = document.createElement('li');
						const a = document.createElement('a');
						a.textContent = pkg.name;
						a.href = `https://www.npmjs.com/package/${pkg.name}`;
						li.append(a);
						target.append(li);
					}
				}

				if (packages.length === 0) {
					const noResultP = document.createElement('p');
					noResultP.innerText = 'No packages found.';
					template.querySelector('.categories')?.replaceChildren(noResultP);
				}

				resultSlot.replaceChildren(template);
			} catch (error: any) {
				console.error(error);
				resultSlot.innerText = `Something went wrong: ${error?.message || error}`;
			}
		}

		async function getPackages(
			usernameOrScope: string
		): Promise<Array<{ name: string; provenance?: 'trustedPublisher' | boolean }>> {
			const searchRes = await fetch(
				`https://registry.npmjs.org/-/v1/search?popularity=1.0&quality=0.0&maintenance=0.0&size=250&text=maintainer%3A${usernameOrScope}`
			);
			const searchJson = (await searchRes.json()) as {
				objects: Array<{ package: { name: string } }>;
			};
			if (searchJson.objects.length === 0) return [];
			const packages = searchJson.objects.map((obj) => obj.package.name);
			const metaRes = await fetch(`https://npm.antfu.dev/${packages.join('+')}?metadata=true`);
			const metaJson = await metaRes.json();
			return Array.isArray(metaJson) ? metaJson : [metaJson];
		}
	</script>

	<style>
		main {
			padding: 1em;
			max-width: 60rem;
		}

		h1 {
			margin-top: 0;
		}

		form {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5em;
		}

		hr {
			border: 0;
			border-top: 1px solid;
			border-image: var(--npm-border-image);
		}

		.categories {
			display: grid;
			grid-template-columns: repeat(1, 1fr);
			grid-template-rows: repeat(3, auto);
			gap: 4em;
			font-size: 0.875em;

			& > * {
				display: grid;
				gap: 1em;
			}

			@media (min-width: 40rem) {
				grid-template-columns: repeat(3, 1fr);
				gap: 0.5em 1em;
				& > * {
					grid-row: 1 / 4;
					grid-template-rows: subgrid;
				}
			}

			p {
				margin: 0;
				opacity: 0.8;
				line-height: 1.4;
			}
			h3 {
				display: flex;
				align-items: center;
				gap: 0.25em;
				margin: 0;
			}
		}

		ol {
			list-style: none;
			margin: 0;
			padding: 0;
			li:not(:first-child, :last-child) {
				margin-block: 0.5em;
			}
		}

		.loader {
			display: inline-block;
			width: 1em;
			aspect-ratio: 4;
			background: radial-gradient(circle closest-side, currentColor 90%, #0000) 0 / calc(100% / 3)
				100% space;
			clip-path: inset(0 100% 0 0);
			animation: l1 1s steps(4) infinite;
		}
		@keyframes l1 {
			to {
				clip-path: inset(0 -34% 0 0);
			}
		}
	</style>
</Layout>
