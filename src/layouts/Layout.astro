---
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>npm provenance overview</title>
	</head>
	<body>
		<slot />
		<footer>
			<a href="https://astro.build">
				<Image
					src="https://astro.badg.es/v2/built-with-astro/tiny.svg"
					alt="Built with Astro"
					width="120"
					height="20"
					densities={[2]}
					loading="lazy"
					decoding="async"
				/>
			</a>
			<a href="https://github.com/delucis/npm-provenance-overview">Source code on GitHub</a>
		</footer>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}
</style>

<style>
	html,
	body {
		margin: 0;
		height: 100%;
		color-scheme: light dark;
	}
	body {
		border-top: 0.625em solid;
		--npm-border-image: linear-gradient(139deg, #fb8817, #ff4b01, #c12127, #e02aff) 3;
		border-image: var(--npm-border-image);
		display: flex;
		flex-direction: column;
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			Roboto,
			Oxygen,
			Ubuntu,
			Cantarell,
			'Open Sans',
			'Helvetica Neue',
			sans-serif;
	}
	footer {
		margin-top: auto;
		padding: 4em 1em 1em;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1em;
		font-size: 0.875em;
		line-height: 0;
	}
</style>
